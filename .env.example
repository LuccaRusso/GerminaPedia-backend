# GerminaPedia Backend — Variáveis de Ambiente
# COPIE ESTE ARQUIVO PARA .env e preencha os valores

# ─── Banco de Dados ───────────────────────────────────────────
# PostgreSQL connection string
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/germinapedia?schema=public"

# ─── JWT ─────────────────────────────────────────────────────
# Gere um secret forte: openssl rand -base64 64
JWT_SECRET="TROQUE_POR_UM_SECRET_FORTE_AQUI_MINIMO_32_CHARS"
JWT_EXPIRES_IN="7d"

# ─── Servidor ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Frontend ────────────────────────────────────────────────
# URL do frontend (para CORS)
FRONTEND_URL="http://localhost:5173"
